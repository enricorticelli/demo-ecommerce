---
import '../styles/global.css';
const { title = 'CQRS E-Commerce' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <main class="mx-auto max-w-6xl p-4 md:p-8">
      <slot />
    </main>
  </body>
</html>
