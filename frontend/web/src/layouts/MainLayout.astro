---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.svelte';
import ToastContainer from '../components/ToastContainer.svelte';

const { title = 'Storefront' } = Astro.props;
---

<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f6f6f7" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700;800&family=Public+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title} | Commerce</title>
  </head>
  <body class="flex min-h-screen flex-col">
    <SiteHeader client:load />
    <main class="mx-auto w-full max-w-[1280px] flex-1 px-4 pb-16 pt-6 md:px-8 md:pt-8">
      <slot />
    </main>
    <footer class="mt-16 border-t border-[#e1e3e5] bg-white py-10 text-center text-xs text-[#6d7175]">
      <p>Commerce</p>
      <p class="mt-1">Catalogo · Carrello · Checkout · Tracking Ordini</p>
    </footer>
    <ToastContainer client:load />
  </body>
</html>
