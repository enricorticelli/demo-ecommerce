---
import MainLayout from '../../layouts/MainLayout.astro';
import AdminOrderDetailPage from '../../components/AdminOrderDetailPage.svelte';
import { ADMIN_PERMISSION, getAdminPermissionsFromCookies } from '../../lib/permissions';

const { id } = Astro.params;
const permissions = getAdminPermissionsFromCookies(Astro.cookies);
const canWriteOrders = permissions.has(ADMIN_PERMISSION.ordersWrite);
---

<MainLayout title="Dettaglio ordine">
  <AdminOrderDetailPage client:load orderId={id ?? ''} canWrite={canWriteOrders} />
</MainLayout>
