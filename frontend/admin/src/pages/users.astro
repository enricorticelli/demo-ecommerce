---
import MainLayout from '../layouts/MainLayout.astro';
import AdminUsersPage from '../components/AdminUsersPage.svelte';
import { ADMIN_PERMISSION, getAdminPermissionsFromCookies, isAdminSuperUserFromCookies } from '../lib/permissions';

const permissions = getAdminPermissionsFromCookies(Astro.cookies);
const isSuperUser = isAdminSuperUserFromCookies(Astro.cookies);
const canWriteAccounts = permissions.has(ADMIN_PERMISSION.accountWrite);

if (!isSuperUser) {
  return Astro.redirect('/', 302);
}
---

<MainLayout title="Utenti">
  <AdminUsersPage client:load canWrite={canWriteAccounts} />
</MainLayout>