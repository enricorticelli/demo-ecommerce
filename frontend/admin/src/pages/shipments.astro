---
import MainLayout from '../layouts/MainLayout.astro';
import AdminShipmentsPage from '../components/AdminShipmentsPage.svelte';
import { ADMIN_PERMISSION, getAdminPermissionsFromCookies } from '../lib/permissions';

const permissions = getAdminPermissionsFromCookies(Astro.cookies);
const canWriteShipping = permissions.has(ADMIN_PERMISSION.shippingWrite);
---

<MainLayout title="Spedizioni">
  <AdminShipmentsPage client:load canWrite={canWriteShipping} />
</MainLayout>
