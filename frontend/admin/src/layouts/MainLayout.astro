---
import '../styles/global.css';
import { ADMIN_PERMISSION, getAdminPermissionsFromCookies, isAdminSuperUserFromCookies } from '../lib/permissions';

const { title = 'Backoffice' } = Astro.props;
const inactivityTimeoutMs = 15 * 60 * 1000;
const permissions = getAdminPermissionsFromCookies(Astro.cookies);

const canReadCatalog = permissions.has(ADMIN_PERMISSION.catalogRead);
const canReadOrders = permissions.has(ADMIN_PERMISSION.ordersRead);
const canReadShipping = permissions.has(ADMIN_PERMISSION.shippingRead);
const canReadWarehouse = permissions.has(ADMIN_PERMISSION.warehouseRead);
const canReadAccounts = permissions.has(ADMIN_PERMISSION.accountRead);
const isSuperUser = isAdminSuperUserFromCookies(Astro.cookies);
---

<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f4f7fb" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700;800&family=Public+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title} | Backoffice</title>
  </head>
  <body class="flex min-h-screen flex-col">
    <header class="border-b border-[#d9dee8] bg-white">
      <div class="mx-auto flex w-full max-w-[1440px] items-center justify-between gap-3 px-4 py-4 md:px-8">
        <a href="/" class="flex items-center gap-3">
          <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-[#0b5fff] text-sm font-bold text-white">BO</span>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#3e4b5d]">Commerce</p>
            <p class="font-title text-lg font-extrabold text-[#1c2430]">Backoffice Gestionale</p>
          </div>
        </a>
        <div class="flex flex-wrap items-center justify-end gap-2">
          <a href="http://localhost:3000" target="_blank" rel="noreferrer" class="btn-secondary">Apri Store</a>
          <a href="/logout" class="btn-secondary">Esci</a>
        </div>
      </div>
      <div class="mx-auto w-full max-w-[1440px] px-4 pb-4 md:px-8">
        <nav class="flex flex-wrap items-center gap-2 text-sm font-semibold text-[#374457]">
          <a href="/" class="btn-secondary">Dashboard</a>
          {canReadCatalog && <a href="/catalog" class="btn-secondary">Catalogo</a>}
          {canReadOrders && <a href="/orders" class="btn-secondary">Ordini</a>}
          {canReadAccounts && <a href="/customers" class="btn-secondary">Clienti</a>}
          {isSuperUser && <a href="/users" class="btn-secondary">Utenti</a>}
          {canReadShipping && <a href="/shipments" class="btn-secondary">Spedizioni</a>}
          {canReadWarehouse && <a href="/warehouse" class="btn-secondary">Magazzino</a>}
        </nav>
      </div>
    </header>
    <main class="mx-auto w-full max-w-[1440px] flex-1 px-4 pb-12 pt-6 md:px-8 md:pt-8">
      <slot />
    </main>
    <script is:inline define:vars={{ inactivityTimeoutMs }}>
      (() => {
        const timeoutMs = Number(inactivityTimeoutMs);
        const activityEvents = ['pointerdown', 'pointermove', 'keydown', 'scroll', 'touchstart'];
        let timerId;

        const restartTimer = () => {
          if (timerId) {
            clearTimeout(timerId);
          }

          timerId = setTimeout(() => {
            window.location.assign('/logout');
          }, timeoutMs);
        };

        activityEvents.forEach((eventName) => {
          window.addEventListener(eventName, restartTimer, { passive: true });
        });

        document.addEventListener('visibilitychange', () => {
          if (document.visibilityState === 'visible') {
            restartTimer();
          }
        });

        restartTimer();
      })();
    </script>
  </body>
</html>
