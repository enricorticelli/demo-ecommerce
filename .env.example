# ============================================================
# Runtime applicazione e URL pubblici
# ============================================================
ASPNETCORE_ENVIRONMENT=Development
PUBLIC_GATEWAY_URL=http://localhost:18080
GATEWAY_INTERNAL_URL=http://gateway-api:8080
FRONTEND_URL=http://localhost:13000
HOST=0.0.0.0
CHOKIDAR_USEPOLLING=true
CHOKIDAR_INTERVAL=250

# ============================================================
# Porte host Docker (override locale per evitare conflitti)
# ============================================================
POSTGRES_HOST_PORT=55432
RABBITMQ_HOST_PORT=55672
RABBITMQ_MANAGEMENT_HOST_PORT=15673
ASPIRE_DASHBOARD_HOST_PORT=18890
ASPIRE_OTLP_HOST_PORT=18891
PAYMENT_MOCK_GATEWAY_HOST_PORT=18082
KEYCLOAK_HOST_PORT=18081
MAILPIT_SMTP_HOST_PORT=11025
MAILPIT_UI_HOST_PORT=18025
GATEWAY_HOST_PORT=18080
FRONTEND_WEB_HOST_PORT=13000

# ============================================================
# Database PostgreSQL (credenziali + connection string servizi)
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
ConnectionStrings__CatalogDb=Host=postgres;Port=5432;Database=catalog_db;Username=postgres;Password=postgres
ConnectionStrings__CartDb=Host=postgres;Port=5432;Database=cart_db;Username=postgres;Password=postgres
ConnectionStrings__OrderDb=Host=postgres;Port=5432;Database=order_db;Username=postgres;Password=postgres
ConnectionStrings__PaymentDb=Host=postgres;Port=5432;Database=payment_db;Username=postgres;Password=postgres
ConnectionStrings__ShippingDb=Host=postgres;Port=5432;Database=shipping_db;Username=postgres;Password=postgres
ConnectionStrings__WarehouseDb=Host=postgres;Port=5432;Database=warehouse_db;Username=postgres;Password=postgres
ConnectionStrings__CommunicationDb=Host=postgres;Port=5432;Database=communication_db;Username=postgres;Password=postgres

# ============================================================
# Message bus (RabbitMQ)
# ============================================================
MessageBus__Host=rabbitmq
MessageBus__Port=5672
MessageBus__Username=app
MessageBus__Password=app

# ============================================================
# Keycloak locale e introspection Gateway
# ============================================================
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
GATEWAY_BACKOFFICE_CLIENT_SECRET=local-dev-gateway-secret
Gateway__Auth__Authority=http://keycloak:8080/realms/demo-ecommerce
Gateway__Auth__Audience=gateway-backoffice
Gateway__Auth__ClientId=gateway-backoffice
Gateway__Auth__ClientSecret=local-dev-gateway-secret
Gateway__Auth__RequireHttpsMetadata=false
Gateway__Auth__IntrospectionCacheSeconds=45

# ============================================================
# Comunicazioni email (SMTP locale via Mailpit)
# ============================================================
Communication__Smtp__Host=mailpit
Communication__Smtp__Port=1025
Communication__Smtp__FromAddress=no-reply@ecommerce.local
Communication__Smtp__FromName=E-commerce

# ============================================================
# Osservabilita OpenTelemetry
# ============================================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://aspire-dashboard:18889
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# ============================================================
# Payment providers (mock) e URL di redirect frontend
# ============================================================
Payment__Providers__Stripe__CheckoutApiBaseUrl=http://payment-mock-gateway:8080/mock/stripe
Payment__Providers__Stripe__ApiKey=mock_stripe_api_key
Payment__Providers__Stripe__WebhookSecret=mock_stripe_webhook_secret
Payment__Providers__Stripe__ReturnUrlTemplate=http://localhost:13000/payment/return?orderId={orderId}&sessionId={sessionId}&provider={provider}&result=authorized
Payment__Providers__Stripe__CancelUrlTemplate=http://localhost:13000/payment/return?orderId={orderId}&sessionId={sessionId}&provider={provider}&result=cancelled

Payment__Providers__PayPal__CheckoutApiBaseUrl=http://payment-mock-gateway:8080/mock/paypal
Payment__Providers__PayPal__ApiKey=mock_paypal_api_key
Payment__Providers__PayPal__WebhookSecret=mock_paypal_webhook_secret
Payment__Providers__PayPal__ReturnUrlTemplate=http://localhost:13000/payment/return?orderId={orderId}&sessionId={sessionId}&provider={provider}&result=authorized
Payment__Providers__PayPal__CancelUrlTemplate=http://localhost:13000/payment/return?orderId={orderId}&sessionId={sessionId}&provider={provider}&result=cancelled

Payment__Providers__Satispay__CheckoutApiBaseUrl=http://payment-mock-gateway:8080/mock/satispay
Payment__Providers__Satispay__ApiKey=mock_satispay_api_key
Payment__Providers__Satispay__WebhookSecret=mock_satispay_webhook_secret
Payment__Providers__Satispay__ReturnUrlTemplate=http://localhost:13000/payment/return?orderId={orderId}&sessionId={sessionId}&provider={provider}&result=authorized
Payment__Providers__Satispay__CancelUrlTemplate=http://localhost:13000/payment/return?orderId={orderId}&sessionId={sessionId}&provider={provider}&result=cancelled

# ============================================================
# Mock gateway pagamenti (checkout pubblico + webhook verso gateway)
# ============================================================
MockGateway__PublicBaseUrl=http://localhost:18082
MockGateway__PaymentWebhookBaseUrl=http://gateway-api:8080
MockGateway__Providers__Stripe__WebhookSecret=mock_stripe_webhook_secret
MockGateway__Providers__PayPal__WebhookSecret=mock_paypal_webhook_secret
MockGateway__Providers__Satispay__WebhookSecret=mock_satispay_webhook_secret
