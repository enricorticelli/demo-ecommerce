ASPNETCORE_ENVIRONMENT=Development
FRONTEND_URL=http://localhost:3000
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

ConnectionStrings__CatalogDb=Host=postgres;Port=5432;Database=catalog_db;Username=postgres;Password=postgres
ConnectionStrings__CartDb=Host=postgres;Port=5432;Database=cart_db;Username=postgres;Password=postgres
ConnectionStrings__OrderDb=Host=postgres;Port=5432;Database=order_db;Username=postgres;Password=postgres
ConnectionStrings__PaymentDb=Host=postgres;Port=5432;Database=payment_db;Username=postgres;Password=postgres
ConnectionStrings__ShippingDb=Host=postgres;Port=5432;Database=shipping_db;Username=postgres;Password=postgres
ConnectionStrings__WarehouseDb=Host=postgres;Port=5432;Database=warehouse_db;Username=postgres;Password=postgres
ConnectionStrings__CommunicationDb=Host=postgres;Port=5432;Database=communication_db;Username=postgres;Password=postgres

MessageBus__Host=rabbitmq
MessageBus__Port=5672
MessageBus__Username=app
MessageBus__Password=app

Communication__Smtp__Host=mailpit
Communication__Smtp__Port=1025
Communication__Smtp__FromAddress=no-reply@ecommerce.local
Communication__Smtp__FromName=E-commerce

OTEL_EXPORTER_OTLP_ENDPOINT=http://aspire-dashboard:18889
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

Payment__Providers__Stripe__CheckoutApiBaseUrl=http://payment-mock-gateway:8080/mock/stripe
Payment__Providers__Stripe__ApiKey=mock_stripe_api_key
Payment__Providers__Stripe__WebhookSecret=mock_stripe_webhook_secret
Payment__Providers__Stripe__ReturnUrlTemplate=http://localhost:3000/payment/return?orderId={orderId}&sessionId={sessionId}&provider={provider}&result=authorized
Payment__Providers__Stripe__CancelUrlTemplate=http://localhost:3000/payment/return?orderId={orderId}&sessionId={sessionId}&provider={provider}&result=cancelled

Payment__Providers__PayPal__CheckoutApiBaseUrl=http://payment-mock-gateway:8080/mock/paypal
Payment__Providers__PayPal__ApiKey=mock_paypal_api_key
Payment__Providers__PayPal__WebhookSecret=mock_paypal_webhook_secret
Payment__Providers__PayPal__ReturnUrlTemplate=http://localhost:3000/payment/return?orderId={orderId}&sessionId={sessionId}&provider={provider}&result=authorized
Payment__Providers__PayPal__CancelUrlTemplate=http://localhost:3000/payment/return?orderId={orderId}&sessionId={sessionId}&provider={provider}&result=cancelled

Payment__Providers__Satispay__CheckoutApiBaseUrl=http://payment-mock-gateway:8080/mock/satispay
Payment__Providers__Satispay__ApiKey=mock_satispay_api_key
Payment__Providers__Satispay__WebhookSecret=mock_satispay_webhook_secret
Payment__Providers__Satispay__ReturnUrlTemplate=http://localhost:3000/payment/return?orderId={orderId}&sessionId={sessionId}&provider={provider}&result=authorized
Payment__Providers__Satispay__CancelUrlTemplate=http://localhost:3000/payment/return?orderId={orderId}&sessionId={sessionId}&provider={provider}&result=cancelled

MockGateway__PublicBaseUrl=http://localhost:8082
MockGateway__PaymentWebhookBaseUrl=http://gateway-api:8080
MockGateway__Providers__Stripe__WebhookSecret=mock_stripe_webhook_secret
MockGateway__Providers__PayPal__WebhookSecret=mock_paypal_webhook_secret
MockGateway__Providers__Satispay__WebhookSecret=mock_satispay_webhook_secret

PUBLIC_GATEWAY_URL=http://localhost:8080
HOST=0.0.0.0
CHOKIDAR_USEPOLLING=true
CHOKIDAR_INTERVAL=250
